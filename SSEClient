import Foundation
import UIKit

class SSEClient: NSObject, URLSessionDataDelegate {
    
    private let parser = SSEParser()
    private var pcmPlayer = PCMAudioPlayer(sampleRate: 24000,
                                   channels: 1,
                                   bufferTime: 0.2,
                                   chunkTime: 0.2)
    
    private var session: URLSession?
    private var task: URLSessionDataTask?
    
    private var currentIndex = 0
    private var currentText = ""
    private var words = [SSESubtitleWordModel]()
    
    override init() {
        super.init()
        
        setupParser()
        pcmPlayer.onPlaybackFinished = { [weak self] in

        }
        
        pcmPlayer.onProgress = { [weak self] time in
            guard let self = self else {return}
            let text = self.updateSubtitle(words: self.words, currentTime: time)

            
        }
        
    }
    
    private func setupSession(){
        let config = URLSessionConfiguration.default
        config.requestCachePolicy = .reloadIgnoringLocalCacheData
        config.urlCache = nil
        
        session = URLSession(configuration: config, delegate: self, delegateQueue: nil)
    }
    
    private func setupParser() {
        parser.onEvent = { [weak self] event, data in
            self?.handleEvent(event: event, data: data)
        }
    }
    
    private func handleEvent(event: String?, data: String) {
        DispatchQueue.main.async{
            switch event {
            case "audio":
                if let pcmData = Data(base64Encoded: data){
                    self.pcmPlayer.appendPCMData(pcmData)
                    print("SSEClient 添加 pcm 成功", data)

                }
            case "text":
                print("SSEClient 播放文字", data)
                
            case "ios_open":
                
                self.pcmPlayer.reset()
                self.currentIndex = 0
                self.currentText = ""
                self.words.removeAll()
                
                
            case "ios_close":
                break
                
            case "TTS_SUBTITLE":
                if let jsondata = data.data(using: .utf8) {
                    if let model = try? JSONDecoder().decode(SSESubtitleModel.self, from: jsondata){
                        if let worlds = model.words{
                            self.words.append(contentsOf: worlds)
                        }
                    }
                }
            default:
                print("未知 event:", event ?? "nil", "  data: ",data)
            }
        }
    }
    
    func updateSubtitle(words: [SSESubtitleWordModel], currentTime: Double) -> String {
        while currentIndex < words.count {
            let w = words[currentIndex]
            
            if currentTime >= w.startTime {
                currentText += w.word
                currentIndex += 1
            } else {
                break
            }
        }
        
        return currentText
    }
    
    func connect(message: String) {
        
        disconnect()
        
        setupSession()
        
        var request = URLRequest(url: URL(string: "https://x")!)
        request.httpMethod = "POST"
        
        // 2. 设置请求头
        request.setValue("text/event-stream", forHTTPHeaderField: "Accept")
        request.setValue("application/json", forHTTPHeaderField: "Content-Type")
        
        // 3. 设置请求体
        let postData: [String: Any] = [
            "x1": "",
            "x2": "",
            "x3": message
        ]
        
        request.httpBody = try? JSONSerialization.data(withJSONObject: postData)
        
        self.task = session?.dataTask(with: request)
        self.task?.resume()
    }
    
    // 👇 核心：收到数据 → 喂给 parser
    func urlSession(_ session: URLSession, dataTask: URLSessionDataTask, didReceive data: Data) {
        parser.append(data)
    }
    
    func urlSession(_ session: URLSession, dataTask: URLSessionDataTask, didReceive response: URLResponse, completionHandler: @escaping (URLSession.ResponseDisposition) -> Void) {
        guard let httpResponse = response as? HTTPURLResponse else {
            completionHandler(.cancel)
            return
        }
        
        if (200...299).contains(httpResponse.statusCode) {
            print("SSEClient 连接成功",httpResponse.statusCode)
            handleEvent(event: "ios_open", data: "")
            completionHandler(.allow)
        } else {
             DispatchQueue.main.async { [weak self] in
                 print("SSEClient 连接失败", httpResponse.statusCode)
                 self?.handleEvent(event: "ios_close", data: "")
            }
            completionHandler(.cancel)
        }
    }
    
    func urlSession(_ session: URLSession, task: URLSessionTask, didCompleteWithError error: Error?) {
        // 如果是主动取消，通常不视为错误
        if let error = error as NSError?, error.code == NSURLErrorCancelled {
            return
        }
        
        DispatchQueue.main.async { [weak self] in
            let statusCode = (task.response as? HTTPURLResponse)?.statusCode
            print("SSEClient 关闭连接", statusCode, error)
            self?.handleEvent(event: "ios_close", data: "")
        }
    }
    
    func disconnect(){
        task?.cancel()
        session?.invalidateAndCancel()
        task = nil
        session = nil
    }
}


class SSEParser {
    
    private var buffer = ""
    
    // 👇 对外回调
    var onEvent: ((String?, String) -> Void)?
    
    func append(_ data: Data) {
        guard let chunk = String(data: data, encoding: .utf8) else { return }
        buffer += chunk
        
        while let range = buffer.range(of: "\n\n") {
            let message = String(buffer[..<range.lowerBound])
            buffer = String(buffer[range.upperBound...])
            
            parse(message)
        }
    }
    
    private func parse(_ message: String) {
        var event: String?
        var dataLines: [String] = []
        
        for line in message.split(separator: "\n") {
            if line.hasPrefix("event:") {
                event = line.dropFirst(6).trimmingCharacters(in: .whitespaces)
            } else if line.hasPrefix("data:") {
                dataLines.append(line.dropFirst(5).trimmingCharacters(in: .whitespaces))
            }
        }
        
        let data = dataLines.joined(separator: "\n")
        
        // 👇 抛给外面
        onEvent?(event, data)
    }
}

struct SSESubtitleModel: Codable{
    var words: [SSESubtitleWordModel]?
}

struct SSESubtitleWordModel: Codable{
    var startTime: Double
    var word: String
}
